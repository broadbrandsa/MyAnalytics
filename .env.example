# ============================================================================
# Broadbrand Analytics — environment variables
# See docs/08-OAUTH-SETUP-RUNBOOK.md §E. Copy to .env.local for local dev.
# In Vercel, mark everything except NEXT_PUBLIC_* as "Sensitive".
# ============================================================================

# --- Public (safe for the browser: Supabase URL + anon key ONLY) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server secrets (NEVER expose to the client) ---
SUPABASE_SERVICE_ROLE_KEY=

# Google (one agency OAuth grant: GA4 + Search Console + Google Ads)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Meta (system-user token flow)
META_APP_ID=
META_APP_SECRET=

# Cron auth — random 32+ char string; Vercel sends it as `Authorization: Bearer ${CRON_SECRET}`
CRON_SECRET=

# Signs the client access-code cookie (HMAC). Random 32+ chars.
ACCESS_COOKIE_SECRET=

# Optional: Slack-compatible webhook for ops alerts (sync failures, needs_reauth,
# Meta token refresh failure). Leave blank to disable alerting.
ALERT_WEBHOOK_URL=

# Base URL used to build absolute URLs for internal fan-out (sync workers) and OAuth redirects.
# Local: http://localhost:3000 ; Prod: https://analytics.broadbrand.co.za
NEXT_PUBLIC_SITE_URL=http://localhost:3000
